# ============================================================================
# .env.example — FG Sales Agent Ecosystem
# Copy to .env and fill in your values. Never commit .env to git.
# ============================================================================

# ── Required ─────────────────────────────────────────────────────────────────
# Anthropic API key — get from console.anthropic.com/api-keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Environment mode ─────────────────────────────────────────────────────────
# lab       = haiku model (~$0.001/call), emails suppressed, 10x relaxed budgets
# production = opus model, full guardrails, real emails
FG_ENV=lab

# ── Email approvals ───────────────────────────────────────────────────────────
# Outlook SMTP — the account that SENDS approval request emails
# Use an app-specific password (not your login password)
# Generate at: account.microsoft.com → Security → App passwords
OUTLOOK_SENDER=kphipps@firstgenesis.com
OUTLOOK_PASSWORD=your-app-password

# Stage gate approvers (already configured in code — for reference)
# CHARTER_APPROVAL    → tjohnson@firstgenesis.com  (CC: pwatty, emathieu)
# REQUIREMENTS        → kphipps@firstgenesis.com   (CC: tjohnson, emathieu)
# QA_AUDIT            → emathieu@firstgenesis.com  (CC: tjohnson)
# DELIVERY            → tjohnson@firstgenesis.com  (CC: pwatty)
# BUDGET_ESCALATION   → pwatty@firstgenesis.com    (CC: emathieu)
# DOCUMENT_CLEARANCE  → kphipps@firstgenesis.com   (CC: emathieu, tjohnson)
# LAB_SIGN_OFF        → tjohnson@firstgenesis.com  (CC: pwatty)
# SME_REVIEW          → kphipps@firstgenesis.com   (CC: emathieu)

# ── Dashboard ─────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-before-production
# DATABASE_URL defaults to sqlite:////data/fg_dashboard.db inside the container

# ── Agent schedule (used by scheduler container) ─────────────────────────────
# Cron expressions — all times UTC
SCHEDULE_PM_AGENT=0 6 * * *        # 6:00 AM UTC daily
SCHEDULE_BA_QA_AGENTS=0 9 * * *    # 9:00 AM UTC daily
SCHEDULE_MANAGER_REPORT=0 17 * * * # 5:00 PM UTC daily
